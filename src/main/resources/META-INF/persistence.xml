<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="backoffice-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>java.com.backoffice.models.Client</class>
        <class>java.com.backoffice.models.Hotel</class>
        <class>java.com.backoffice.models.Reservation</class>

        <!-- Les propriétés sont injectées dynamiquement depuis application.properties via JPAUtil -->
    </persistence-unit>
</persistence>
