<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="backoffice-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.backoffice.models.Client</class>
        <class>com.backoffice.models.Hotel</class>
        <class>com.backoffice.models.Reservation</class>
        <class>com.backoffice.models.Vehicule</class>
        <class>com.backoffice.models.TypeCarburant</class>
        <class>com.backoffice.models.Token</class>
        <class>com.backoffice.models.Lieu</class>
        <class>com.backoffice.models.Distance</class>
        <class>com.backoffice.models.Parametre</class>
        <class>com.backoffice.models.ConfigurationAttente</class>
        <class>com.backoffice.models.Planification</class>
        <class>com.backoffice.models.Regroupement</class>
        <class>com.backoffice.models.RegroupementReservation</class>
        <class>com.backoffice.models.AssignationVehicule</class>
        <class>com.backoffice.models.ItineraireArret</class>
        <class>com.backoffice.models.SuiviTrajetVehicule</class>

        <!-- Les propriétés sont injectées dynamiquement depuis application.properties via JPAUtil -->
    </persistence-unit>
</persistence>
