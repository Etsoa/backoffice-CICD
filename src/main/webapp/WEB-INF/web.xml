<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- Scan automatique de tous les packages dans src/main/java -->
    <context-param>
        <param-name>packagesToScan</param-name>
        <param-value></param-value>
    </context-param>

    <!-- Répertoire de base pour les vues (JSP, HTML, etc.) -->
    <context-param>
        <param-name>viewPath</param-name>
        <param-value>/templates/</param-value>
    </context-param>

    <servlet>
        <servlet-name>FrontServlet</servlet-name>
        <servlet-class>itu.framework.servlet.FrontServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>FrontServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>templates/index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
